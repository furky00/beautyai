# Supabase - https://supabase.com adresinden alın
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI API - https://platform.openai.com/api-keys adresinden alın
OPENAI_API_KEY=sk-your-openai-key-here

# Kullanılacak model (varsayılan: gpt-4o)
# gpt-4o          → En güçlü, vision destekli, önerilen
# gpt-4o-mini     → Daha hızlı ve ekonomik, vision destekli
OPENAI_MODEL=gpt-4o

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
